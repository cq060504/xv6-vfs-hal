+      vnode_table[i].ops = 0;
+      vnode_table[i].mp = 0;
+      vnode_table[i].priv = 0;
+      vnode_table[i].inum = 0;
+      vnode_table[i].major = 0;
+      vnode_table[i].minor = 0;
+      release(&vnode_lock);
+      return &vnode_table[i];
+    }
+  }
+  release(&vnode_lock);
+  return 0;
