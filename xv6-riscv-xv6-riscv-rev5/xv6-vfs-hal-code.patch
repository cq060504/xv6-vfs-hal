+    // 清理
+    unlink("/mnt/l3dir/l3sub/l3file");
+    unlink("/mnt/l3dir/l3sub");
+    unlink("/mnt/l3dir");
+    umount("/mnt");
+    printf("\033[32mPASS\033[0m");
+  }
+  return 0;
