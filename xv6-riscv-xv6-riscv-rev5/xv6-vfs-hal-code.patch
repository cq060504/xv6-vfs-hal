--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_swtch.S
@@ -0,0 +1,41 @@
+# Context switch for LoongArch64.
+#
+#   void swtch(struct hal_context *old, struct hal_context *new);
+#
+# Save current callee-saved registers in *old. Load from *new.
+# a0 = old, a1 = new
+#
+# LoongArch callee-saved (12 registers):
+#   ra ($r1), sp ($r3), fp/$s9 ($r22), s0-s8 ($r23-$r31)
+
+.globl swtch
+.globl hal_switch
+hal_switch:
+swtch:
+        st.d    $ra, $a0, 0
+        st.d    $sp, $a0, 8
+        st.d    $fp, $a0, 16
+        st.d    $s0, $a0, 24
+        st.d    $s1, $a0, 32
+        st.d    $s2, $a0, 40
+        st.d    $s3, $a0, 48
+        st.d    $s4, $a0, 56
+        st.d    $s5, $a0, 64
+        st.d    $s6, $a0, 72
+        st.d    $s7, $a0, 80
+        st.d    $s8, $a0, 88
+
+        ld.d    $ra, $a1, 0
+        ld.d    $sp, $a1, 8
+        ld.d    $fp, $a1, 16
+        ld.d    $s0, $a1, 24
+        ld.d    $s1, $a1, 32
+        ld.d    $s2, $a1, 40
+        ld.d    $s3, $a1, 48
+        ld.d    $s4, $a1, 56
+        ld.d    $s5, $a1, 64
+        ld.d    $s6, $a1, 72
+        ld.d    $s7, $a1, 80
+        ld.d    $s8, $a1, 88
+
+        jirl    $r0, $ra, 0
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tlbrefill.S b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tlbrefill.S
new file mode 100644
index 0000000..21aee24
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tlbrefill.S
@@ -0,0 +1,72 @@
+# LoongArch software TLB refill handler.
+#
+# The CPU enters here through CSR.TLBRENTRY with DA=1/PG=0, so low
+# physical addresses are directly reachable. The page-table layout is the
+# four-level 9-9-9-9 scheme configured in kvminithart() via PWCL/PWCH.
+
+.section .tlbrefill, "ax"
+.balign 4096
+.globl tlb_refill_entry
+tlb_refill_entry:
+        # Use TLBRSAVE as the single scratch save slot; do not touch ERA/PRMD.
+        csrwr   $t0, 0x8b              # TLBRSAVE
+
+        # TLBREHI.VPPN is set by hardware, but PS is software-owned.
+        csrrd   $t0, 0x8e              # TLBREHI
+        srli.d  $t0, $t0, 6
+        slli.d  $t0, $t0, 6
+        ori     $t0, $t0, 12
+        csrwr   $t0, 0x8e
+
+        # Reject non-user VAs before lddir can truncate them to 48 bits.
+        csrrd   $t0, 0x89              # TLBRBADV
+        srli.d  $t0, $t0, 38           # MAXVA is 1 << 38
+        bnez    $t0, .Ltlbr_invalid
+        csrrd   $t0, 0x89
+        srli.d  $t0, $t0, 13           # reject VA < 2*PGSIZE
+        beqz    $t0, .Ltlbr_invalid
+
+        csrrd   $t0, 0x19              # PGDL: root page-table physical base
+
+        lddir   $t0, $t0, 3            # Dir2, VA[47:39]
+        andi    $t0, $t0, 1
+        beqz    $t0, .Ltlbr_invalid
+        csrrd   $t0, 0x19
+        lddir   $t0, $t0, 3
+        addi.d  $t0, $t0, -1
+
+        lddir   $t0, $t0, 2            # Dir1, VA[38:30]
+        andi    $t0, $t0, 1
+        beqz    $t0, .Ltlbr_invalid
+        csrrd   $t0, 0x19
+        lddir   $t0, $t0, 3
+        addi.d  $t0, $t0, -1
+        lddir   $t0, $t0, 2
+        addi.d  $t0, $t0, -1
+
+        lddir   $t0, $t0, 1            # Dir0, VA[29:21]
+        andi    $t0, $t0, 1
+        beqz    $t0, .Ltlbr_invalid
+        csrrd   $t0, 0x19
+        lddir   $t0, $t0, 3
+        addi.d  $t0, $t0, -1
+        lddir   $t0, $t0, 2
+        addi.d  $t0, $t0, -1
+        lddir   $t0, $t0, 1
+        addi.d  $t0, $t0, -1
+
+        ldpte   $t0, 0                 # even page -> TLBRELO0
+        ldpte   $t0, 1                 # odd page  -> TLBRELO1
+        tlbfill
+
+        csrrd   $t0, 0x8b
+        ertn
+
+.Ltlbr_invalid:
+        # Install an invalid matching entry so retry reaches the normal
+        # PIL/PIS/PIF path instead of looping forever in TLB refill.
+        csrwr   $r0, 0x8c              # TLBRELO0
+        csrwr   $r0, 0x8d              # TLBRELO1
+        tlbfill
+        csrrd   $t0, 0x8b
+        ertn
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tramp.S b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tramp.S
new file mode 100644
index 0000000..e09ad37
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_tramp.S
@@ -0,0 +1,140 @@
+# LoongArch64 user <-> kernel trap trampoline.
+#
+# When a user-space (PLV3) trap occurs:
+#   Hardware saves: CRMD.PLV -> PRMD.PPLV, CRMD.IE -> PRMD.PIE
+#                   PC -> ERA, CRMD.PLV=0, CRMD.IE=0, PC=EENTRY
+#
+# DMW0 (VSEG=0, PLV0=1) identity-maps all VA[63:60]=0 for kernel mode,
+# so the kernel accesses physical addresses directly.  The trampoline is
+# placed at its flash LMA (0x1C008000) so DMW0 reaches the real code.
+#
+# Trapframe access: KSave1 (CSR 0x31) holds the *kernel* virtual address
+# of the current process's trapframe (p->trapframe).  This KVA is in the
+# DMW0 identity-mapped window, so uservec/userret can read/write the
+# trapframe without going through the user page table or the TRAPFRAME VA.
+#
+# KSave0 (CSR 0x30) is used to save/restore user a0 across the transition.
+
+#include "arch.h"
+#include "memlayout.h"
+
+.section trampsec
+.globl trampoline
+.globl usertrap
+
+trampoline:
+.align 4
+.globl uservec
+uservec:
+        # Swap user a0 with KSave0; then load trapframe KVA from KSave1.
+        csrwr   $a0, 0x30              # KSave0=user_a0 (a0 gets old KSave0, ignored)
+        csrrd   $a0, 0x31              # a0 = KSave1 = p->trapframe (KVA, DMW0-accessible)
+
+        # Save all user registers to trapframe via KVA (DMW0 identity-mapped).
+        # Offsets match struct trapframe in proc.h.
+        st.d    $ra, $a0, 40
+        st.d    $sp, $a0, 48
+        st.d    $r0, $a0, 56           # gp slot -- LoongArch has no gp
+        st.d    $tp, $a0, 64
+        st.d    $t0, $a0, 72
+        st.d    $t1, $a0, 80
+        st.d    $t2, $a0, 88
+        st.d    $s0, $a0, 96
+        st.d    $s1, $a0, 104
+        st.d    $a1, $a0, 120
+        st.d    $a2, $a0, 128
+        st.d    $a3, $a0, 136
+        st.d    $a4, $a0, 144
+        st.d    $a5, $a0, 152
+        st.d    $a6, $a0, 160
+        st.d    $a7, $a0, 168
+        st.d    $s2, $a0, 176
+        st.d    $s3, $a0, 184
+        st.d    $s4, $a0, 192
+        st.d    $s5, $a0, 200
+        st.d    $s6, $a0, 208
+        st.d    $s7, $a0, 216
+        st.d    $s8, $a0, 224
+        st.d    $fp, $a0, 232          # fp = $r22 (s9 slot)
+        st.d    $r0, $a0, 240          # s10 slot -- no LA equivalent
+        st.d    $r0, $a0, 248          # s11 slot
+        st.d    $t3, $a0, 256
+        st.d    $t4, $a0, 264
+        st.d    $t5, $a0, 272
+        st.d    $t6, $a0, 280
+
+        # Recover user a0 from KSave0 and store to trapframe->a0.
+        csrrd   $t0, 0x30
+        st.d    $t0, $a0, 112
+
+        # Save user pc (ERA) to trapframe->epc.
+        csrrd   $t0, 0x6               # ERA
+        st.d    $t0, $a0, 24
+
+        # Load kernel stack pointer from trapframe.
+        ld.d    $sp, $a0, 8
+
+        # Load kernel hartid into tp.
+        ld.d    $tp, $a0, 32
+
+        # Load address of usertrap() handler.
+        ld.d    $t0, $a0, 16
+
+        # Load kernel page table base.
+        ld.d    $t1, $a0, 0
+
+        # Switch to kernel page table (no invtlb — kernel uses DMW, not TLB).
+        csrwr   $t1, 0x19              # PGDL = kernel page table
+
+        # Call usertrap().  Use $ra so usertrap() can return to userret.
+        jirl    $ra, $t0, 0
+
+.globl userret
+userret:
+        # usertrap() returns here with the user page table in a0.
+
+        # Switch to user page table.
+        csrwr   $a0, 0x19              # PGDL = user page table
+        invtlb  0, $r0, $r0
+
+        # Load trapframe KVA from KSave1 (DMW0-accessible, per-process).
+        csrrd   $a0, 0x31              # a0 = p->trapframe KVA
+
+        # Restore all user registers from trapframe.
+        # a0 is the base pointer, restored LAST.
+        ld.d    $ra, $a0, 40
+        ld.d    $sp, $a0, 48
+        # skip gp -- LoongArch has no gp
+        ld.d    $tp, $a0, 64
+        ld.d    $t0, $a0, 72
+        ld.d    $t1, $a0, 80
+        ld.d    $t2, $a0, 88
+        ld.d    $s0, $a0, 96
+        ld.d    $s1, $a0, 104
+        ld.d    $a1, $a0, 120
+        ld.d    $a2, $a0, 128
+        ld.d    $a3, $a0, 136
+        ld.d    $a4, $a0, 144
+        ld.d    $a5, $a0, 152
+        ld.d    $a6, $a0, 160
+        ld.d    $a7, $a0, 168
+        ld.d    $s2, $a0, 176
+        ld.d    $s3, $a0, 184
+        ld.d    $s4, $a0, 192
+        ld.d    $s5, $a0, 200
+        ld.d    $s6, $a0, 208
+        ld.d    $s7, $a0, 216
+        ld.d    $s8, $a0, 224
+        ld.d    $fp, $a0, 232
+        ld.d    $t3, $a0, 256
+        ld.d    $t4, $a0, 264
+        ld.d    $t5, $a0, 272
+        ld.d    $t6, $a0, 280
+
+        # Restore user a0 last (it was the base pointer).
+        ld.d    $a0, $a0, 112
+
+        # ERA and PRMD already set by prepare_return() in trap.c.
+        # ertn uses ERA for the return PC and PRMD.PPLV/PIE for
+        # mode/interrupt configuration.
+        ertn
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_uart.c b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_uart.c
new file mode 100644
index 0000000..b3deaa3
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_uart.c
@@ -0,0 +1,106 @@
+// LoongArch 16550a UART driver.
+// Identical logic to RISC-V version; only the UART0 base address differs
+// (provided by memlayout.h).
+
+#include "types.h"
+#include "param.h"
+#include "hal/hal.h"
+#include "spinlock.h"
+#include "proc.h"
+#include "defs.h"
+
+#define Reg(reg) ((volatile unsigned char *)(UART0 + (reg)))
+
+#define ReadReg(reg) (*(Reg(reg)))
+#define WriteReg(reg, v) (*(Reg(reg)) = (v))
+
+#define RHR 0
+#define THR 0
+#define IER 1
+#define IER_RX_ENABLE (1<<0)
+#define IER_TX_ENABLE (1<<1)
+#define FCR 2
+#define FCR_FIFO_ENABLE (1<<0)
+#define FCR_FIFO_CLEAR (3<<1)
+#define ISR 2
+#define LCR 3
+#define LCR_EIGHT_BITS (3<<0)
+#define LCR_BAUD_LATCH (1<<7)
+#define LSR 5
+#define LSR_RX_READY (1<<0)
+#define LSR_TX_IDLE (1<<5)
+
+static struct spinlock tx_lock;
+static int tx_busy;
+static int tx_chan;
+
+extern volatile int panicking;
+extern volatile int panicked;
+
+__attribute__ ((section(".text.entry")))
+void
+uartinit(void)
+{
+  // On QEMU LoongArch: FIFO reset causes internal assertion crash.
+  // Keep UART register config minimal — the emulated UART works with defaults.
+  // Only init the lock for now. Full config deferred to Week 7.
+  initlock(&tx_lock, "uart");
+}
+
+void
+uartwrite(char buf[], int n)
+{
+  for(int i = 0; i < n; i++)
+    uartputc_sync(buf[i]);
+}
+
+void
+uartputc_sync(int c)
+{
+  if(panicking == 0)
+    push_off();
+  if(panicked){
+    for(;;)
+      ;
+  }
+  // QEMU LoongArch UART: LSR polling unreliable. Use delay instead.
+  WriteReg(THR, c);
+  // Small delay to let QEMU process the byte before next write
+  for(volatile int d = 0; d < 50000; d++) asm volatile("");
+  if(panicking == 0)
+    pop_off();
+}
+
+int
+uartgetc(void)
+{
+  if(ReadReg(LSR) & LSR_RX_READY)
+    return ReadReg(RHR);
+  else
+    return -1;
+}
+
+void
+uartintr(void)
+{
+  ReadReg(ISR);
+  acquire(&tx_lock);
+  if(ReadReg(LSR) & LSR_TX_IDLE){
+    tx_busy = 0;
+    wakeup(&tx_chan);
+  }
+  release(&tx_lock);
+  while(1){
+    int c = uartgetc();
+    if(c == -1)
+      break;
+    consoleintr(c);
+  }
+}
+
+// HAL unified interface wrappers
+void hal_console_init(void)                  { uartinit(); }
+void hal_putchar_sync(int c)                 { uartputc_sync(c); }
+void hal_putchar(int c)                      { uartputc_sync(c); }
+int  hal_getchar(void)                       { return uartgetc(); }
+void hal_console_intr(void (*handler)(int))  { uartintr(); }
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_virtio.c b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_virtio.c
new file mode 100644
index 0000000..60ad6f7
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/hal_virtio.c
@@ -0,0 +1,130 @@
+// LoongArch RAM-disk virtio replacement.
+//
+// LoongArch QEMU virt uses PCI-based virtio (not MMIO like RISC-V).
+// Instead of implementing a full PCI enumeration + virtio-over-PCI
+// driver, we embed the filesystem image directly in the kernel binary
+// and serve block I/O from a writable in-memory copy.
+//
+// Each image is converted to an ELF object via objcopy and linked at build
+// time.  Device 1 is fs.img; device 2 is fs1.img when VIRTIO_NDISK=2.
+
+#include "types.h"
+#include "hal/hal.h"
+#include "defs.h"
+#include "param.h"
+#include "spinlock.h"
+#include "sleeplock.h"
+#include "fs.h"
+#include "buf.h"
+
+// Embedded filesystem image boundaries (from objcopy).
+extern char _binary_fs_img_start[];
+extern char _binary_fs_img_end[];
+
+#ifndef VIRTIO_NDISK
+#define VIRTIO_NDISK 1
+#endif
+
+#if VIRTIO_NDISK < 1 || VIRTIO_NDISK > 2
+#error "VIRTIO_NDISK must be 1 or 2"
+#endif
+
+#if VIRTIO_NDISK > 1
+extern char _binary_fs1_img_start[];
+extern char _binary_fs1_img_end[];
+#endif
+
+#define NRAMDISK VIRTIO_NDISK
+#define RAMDISK_MAX_PAGES 2048
+
+struct ramdisk {
+  uchar *pages[RAMDISK_MAX_PAGES];
+  uint npages;
+  uint size;
+  struct spinlock lock;
+};
+
+static struct ramdisk ramdisk[NRAMDISK];
+
+static void
+ramdisk_init(uint idx, char *start, char *end)
+{
+  struct ramdisk *rd = &ramdisk[idx];
+  initlock(&rd->lock, "ramdisk");
+
+  uint64 size = (uint64)end - (uint64)start;
+  if (size == 0)
+    panic("ramdisk_init: empty image");
+  if (size > RAMDISK_MAX_PAGES * PGSIZE)
+    panic("ramdisk_init: image too large");
+
+  rd->npages = (size + PGSIZE - 1) / PGSIZE;
+  rd->size = size;
+
+  // Allocate writable pages and copy from the embedded image.
+  for (uint i = 0; i < rd->npages; i++) {
+    rd->pages[i] = (uchar *)kalloc();
+    if (rd->pages[i] == 0)
+      panic("ramdisk_init: kalloc");
+    memset(rd->pages[i], 0, PGSIZE);
+  }
+
+  uint64 remain = size;
+  for (uint i = 0; i < rd->npages; i++) {
+    uint64 n = remain;
+    if (n > PGSIZE) n = PGSIZE;
+    memmove(rd->pages[i], start + i * PGSIZE, n);
+    remain -= n;
+  }
+
+  printf("ramdisk%d: %d bytes, %d pages\n", idx + 1, rd->size, rd->npages);
+}
+
+static struct ramdisk*
+ramdisk_for_dev(uint dev)
+{
+  if (dev < 1 || dev > NRAMDISK)
+    panic("ramdisk_for_dev");
+  return &ramdisk[dev - 1];
+}
+
+void
+virtio_disk_init(void)
+{
+  ramdisk_init(0, _binary_fs_img_start, _binary_fs_img_end);
+#if VIRTIO_NDISK > 1
+  ramdisk_init(1, _binary_fs1_img_start, _binary_fs1_img_end);
+#endif
+}
+
+void
+virtio_disk_rw(struct buf *b, int write)
+{
+  struct ramdisk *rd = ramdisk_for_dev(b->dev);
+  uint64 offset = b->blockno * BSIZE;
+
+  if (offset + BSIZE > rd->size)
+    panic("virtio_disk_rw: beyond ramdisk");
+
+  acquire(&rd->lock);
+
+  uchar *base = rd->pages[offset / PGSIZE];
+  uint   off  = offset % PGSIZE;
+
+  if (write) {
+    memmove(base + off, b->data, BSIZE);
+  } else {
+    memmove(b->data, base + off, BSIZE);
+  }
+
+  // Synchronous completion.
+  b->disk = 0;
+
+  release(&rd->lock);
+}
+
+void
+virtio_disk_intr(void)
+{
+  // RAM disk completes I/O synchronously.
+}
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/kernel.ld b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/kernel.ld
new file mode 100644
index 0000000..087d1fa
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/kernel.ld
@@ -0,0 +1,67 @@
+OUTPUT_ARCH("loongarch")
+ENTRY(_entry)
+
+SECTIONS
+{
+  /*
+   * Simple layout: everything at VMA 0x1c000000.
+   * .data and .bss have AT() in flash, start() copies them to RAM at 0x00400000.
+   */
+  . = 0x1c000000;
+
+  .text : {
+    *(.text.entry)
+    *hal_entry.o(.text)
+    *hal_start.o(.text)
+    *hal_uart.o(.text)
+  }
+
+  /* TLB refill and trampoline live at fixed pages used by memlayout.h. */
+  . = 0x1c008000;
+  .tlbrefill : {
+    *(.tlbrefill)
+  }
+
+  . = 0x1c009000;
+  .trampoline : {
+    _trampoline = .;
+    *(trampsec)
+    . = ALIGN(0x1000);
+    ASSERT(. - _trampoline == 0x1000, "error: trampoline larger than one page");
+  }
+
+  . = 0x1c00a000;
+  .text.rest : {
+    *(.text .text.*)
+    PROVIDE(etext = .);
+  }
+
+  .rodata : { *(.rodata .rodata.*) }
+  .eh_frame : { *(.eh_frame) }
+
+  /* .data LMA follows eh_frame. VMA goes to RAM. */
+  _data_lma = ALIGN(4096);
+
+  . = 0x00400000;
+  .data : AT(_data_lma) {
+    _data_start = .;
+    *(.data .data.*) *(.got .got.*)
+    . = ALIGN(16);
+  }
+
+  .bss (NOLOAD) : {
+    . = ALIGN(4096);
+    _bss_start = .;
+    *(.bss .bss.*)
+    . = ALIGN(4096);
+    _bss_end = .;
+  }
+
+  .bootstack (NOLOAD) : {
+    . = ALIGN(16);
+    *(.bootstack)
+    . = ALIGN(4096);
+  }
+
+  PROVIDE(end = .);
+}
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/memlayout.h b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/memlayout.h
new file mode 100644
index 0000000..1706fcf
--- /dev/null
+++ b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/memlayout.h
@@ -0,0 +1,66 @@
+// LoongArch physical memory layout for qemu -machine virt (LS7A chipset).
+//
+// Based on QEMU hw/loongarch/virt.c:
+//
+// 00000000 -- Low RAM (256 MB for xv6)
+// 0FE00000 -- EIOINTC (extended I/O interrupt controller)
+// 1FE001E0 -- UART0 (COM1, 16550a)
+// 1C000000 -- Firmware/BIOS flash (kernel loaded here via -bios)
+//
+// DMW0 maps VA[47:36]=0 -> PA[47:36]=0 for kernel direct access.
+// Kernel .data/.bss at VMA 0x00400000 (low RAM).
+// Kernel .text at VMA 0x1c000000 (flash).
+//
+// Kernel stack and low trampoline pages are placed where LoongArch DMW0 can
+// reach the backing physical memory directly. The trapframe is accessed via
+// KSave1, so it does not need a user page-table mapping.
+
+#ifndef _HAL_LOONGARCH_MEMLAYOUT_H_
+#define _HAL_LOONGARCH_MEMLAYOUT_H_
+
+// QEMU puts 16550a UART registers here in physical memory.
+#define UART0 0x1FE001E0L
+#define UART0_IRQ 31
+
+// virtio on LoongArch is PCI-based, not MMIO.
+// VIRTIO0 provides the base for compatibility; actual access goes through PCI.
+#define VIRTIO0 0x10000000L
+#define VIRTIO0_IRQ 32
+
+// Extended I/O Interrupt Controller base address.
+#define EIOINTC 0x0FE00000L
+// PLIC alias for vm.c compatibility (maps PLIC region = EIOINTC region).
+#define PLIC EIOINTC
+#define PLIC_PRIORITY (PLIC + 0x0)
+#define PLIC_PENDING (PLIC + 0x1000)
+
+// Kernel code in flash at VMA 0x1c000000. Kernel data in RAM at 0x00400000.
+// PHYSTOP = start of kernel data in RAM + 124MB usable RAM.
+#define KERNBASE 0x1C000000L
+#define PHYSTOP (0x00400000L + 124*1024*1024)
+
+// LoongArch DMW0 (VSEG=0, PLV=PLV0) identity-maps ALL VA[63:60]=0 -> PA=VA.
+// This covers our entire 39-bit VA space. We exploit this by placing kernel
+// objects at physical addresses where they actually exist:
+//
+//   TRAMPOLINE = 0x1C009000  (_trampoline symbol in flash, after .tlbrefill page)
+//   KSTACK     = 0x08000000+ (low RAM above PHYSTOP, unused by kalloc)
+//   TRAPFRAME  —  per-process, accessed via KSave1 holding p->trapframe KVA
+//
+// TRAMPOLINE is the actual low VA used by EENTRY/userret. TRAPFRAME keeps the
+// original xv6 high user-VA contract for sbrk/usertests only; LoongArch never
+// maps or dereferences that VA on the trap path.
+#define TRAMPOLINE 0x1C009000L
+#define TRAPFRAME  (MAXVA - 2*PGSIZE)
+
+// One byte past the largest user address that sbrk may create.
+// RISC-V uses TRAPFRAME as this guard; keep the same contract for tests.
+#define USER_TOP TRAPFRAME
+
+// Kernel stacks: placed at physical addresses with actual RAM (0x08000000+),
+// below QEMU's 256MB low-RAM ceiling (0x10000000). DMW0 identity-maps VA=PA.
+// 3*PGSIZE per process (2 usable + 1 guard). NPROC=64 → 768KB total.
+#define KSTACK_BASE 0x08000000L
+#define KSTACK(p) (KSTACK_BASE + (p)*3*PGSIZE)
+
+#endif
diff --git a/xv6-riscv-xv6-riscv-rev5/hal/loongarch/user.ld b/xv6-riscv-xv6-riscv-rev5/hal/loongarch/user.ld
